      "gi://Meta": ["./node_modules/@girs/meta-14/index.d.ts"],
      "gi://St": ["./node_modules/@girs/st-14/index.d.ts"],
      "gi://Shell": ["./node_modules/@girs/shell-14/index.d.ts"],
      "gi://Adw": ["./node_modules/@girs/adw-1/index.d.ts"],
