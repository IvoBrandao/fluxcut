<?xml version="1.0" encoding="UTF-8"?>
<schemalist>

  <!-- ======================================================
       WindowTilingControl main settings schema
       ====================================================== -->
  <schema id="org.gnome.shell.extensions.window-tiling-control"
          path="/org/gnome/shell/extensions/window-tiling-control/">

    <!-- Master toggle -->
    <key name="tiling-enabled" type="b">
      <default>true</default>
      <summary>Enable WindowTilingControl</summary>
      <description>Master switch to enable or disable all WindowTilingControl tiling features.</description>
    </key>

    <!-- Feature toggles -->
    <key name="snap-overlay-enabled" type="b">
      <default>true</default>
      <summary>Enable Snap Layout Overlay (Super+Z)</summary>
      <description>Show the Super+Z snap layout picker popup.</description>
    </key>

    <key name="snap-assist-enabled" type="b">
      <default>true</default>
      <summary>Enable Snap Assist</summary>
      <description>After snapping a window, show thumbnail picker for remaining zones.</description>
    </key>

    <key name="drag-zone-highlight-enabled" type="b">
      <default>true</default>
      <summary>Enable Drag Zone Highlights</summary>
      <description>Show zone highlight overlays when dragging a window near a snap zone.</description>
    </key>

    <key name="snap-groups-enabled" type="b">
      <default>true</default>
      <summary>Enable Snap Groups</summary>
      <description>Track and restore groups of snapped windows.</description>
    </key>

    <!-- Window gaps -->
    <key name="window-gap-size" type="u">
      <default>4</default>
      <range min="0" max="40"/>
      <summary>Window Gap Size</summary>
      <description>Gap in pixels between snapped windows and monitor edges.</description>
    </key>

    <!-- Drag behaviour -->
    <key name="drag-edge-threshold" type="u">
      <default>20</default>
      <range min="5" max="100"/>
      <summary>Zone Activation Threshold</summary>
      <description>Pixel distance from a monitor edge that triggers zone highlighting during drag.</description>
    </key>

    <!-- Snap assist -->
    <key name="snap-assist-timeout" type="u">
      <default>8</default>
      <range min="2" max="30"/>
      <summary>Snap Assist Auto-Dismiss Timeout</summary>
      <description>Seconds before the Snap Assist overlay automatically closes.</description>
    </key>

    <!-- Animations -->
    <key name="animation-speed" type="u">
      <default>2</default>
      <range min="0" max="3"/>
      <summary>Animation Speed</summary>
      <description>0 = Off, 1 = Fast (100ms), 2 = Normal (200ms), 3 = Slow (400ms).</description>
    </key>

    <!-- Appearance -->
    <key name="overlay-position" type="s">
      <default>'top-center'</default>
      <summary>Snap Overlay Position</summary>
      <description>Where the Super+Z snap overlay appears: 'top-center' or 'top-right'.</description>
    </key>

    <key name="use-accent-color" type="b">
      <default>true</default>
      <summary>Use System Accent Color</summary>
      <description>Tint zone highlights and overlays with the GNOME accent color (GNOME 47+). When off, the custom colors below are used.</description>
    </key>

    <key name="zone-highlight-color" type="s">
      <default>'rgba(0,120,212,0.30)'</default>
      <summary>Zone Highlight Fill Color</summary>
      <description>RGBA color for inactive zone highlight overlays.</description>
    </key>

    <key name="zone-border-color" type="s">
      <default>'rgba(0,120,212,1.0)'</default>
      <summary>Zone Border Color</summary>
      <description>RGBA color for zone highlight borders and the active zone.</description>
    </key>

    <!-- Rounded corners -->
    <key name="rounded-corners-enabled" type="b">
      <default>false</default>
      <summary>Rounded Window Corners</summary>
      <description>Clip normal windows to rounded corners (disabled on maximized/fullscreen windows).</description>
    </key>

    <key name="rounded-corners-radius" type="u">
      <default>12</default>
      <range min="0" max="40"/>
      <summary>Corner Radius</summary>
      <description>Rounded corner radius in pixels.</description>
    </key>

    <!-- Custom zones (JSON-encoded) -->
    <key name="custom-zone-sets" type="as">
      <default>[]</default>
      <summary>Custom Zone Sets</summary>
      <description>JSON-encoded array of user-defined zone layouts.</description>
    </key>

    <!-- Per-monitor active preset (JSON-encoded) -->
    <key name="monitor-presets" type="as">
      <default>[]</default>
      <summary>Monitor Presets</summary>
      <description>JSON-encoded map of monitor index to active preset ID per workspace.</description>
    </key>

    <!-- Zone editor grid -->
    <key name="zone-editor-grid-columns" type="u">
      <default>12</default>
      <range min="4" max="24"/>
      <summary>Zone Editor Grid Columns</summary>
      <description>Number of column divisions in the zone editor snap grid.</description>
    </key>

    <key name="zone-editor-grid-rows" type="u">
      <default>8</default>
      <range min="4" max="16"/>
      <summary>Zone Editor Grid Rows</summary>
      <description>Number of row divisions in the zone editor snap grid.</description>
    </key>

    <!-- Logging -->
    <key name="log-level" type="u">
      <default>0</default>
      <range min="0" max="4"/>
      <summary>Log Level</summary>
      <description>0 = Off, 1 = Error, 2 = Warn, 3 = Info, 4 = Debug.</description>
    </key>

  </schema>

  <!-- ======================================================
       WindowTilingControl keybindings schema — i3-inspired defaults
       ====================================================== -->
  <schema id="org.gnome.shell.extensions.window-tiling-control.keybindings"
          path="/org/gnome/shell/extensions/window-tiling-control/keybindings/">

    <!-- ── Window Tiling (Super + direction) ────────────────────────── -->

    <key name="snap-left-half" type="as">
      <default><![CDATA[['<Super>Left']]]></default>
      <summary>Tile Left / Navigate Left</summary>
      <description>Snap to left half, or move quarter-tiled window leftward.</description>
    </key>

    <key name="snap-right-half" type="as">
      <default><![CDATA[['<Super>Right']]]></default>
      <summary>Tile Right / Navigate Right</summary>
      <description>Snap to right half, or move quarter-tiled window rightward.</description>
    </key>

    <key name="snap-upper-quarter" type="as">
      <default><![CDATA[['<Super>Up']]]></default>
      <summary>Tile Up / Navigate Up</summary>
      <description>Snap to upper quarter, or move quarter-tiled window upward.</description>
    </key>

    <key name="snap-lower-quarter" type="as">
      <default><![CDATA[['<Super>Down']]]></default>
      <summary>Tile Down / Navigate Down</summary>
      <description>Snap to lower quarter, or move quarter-tiled window downward.</description>
    </key>

    <!-- ── Direct Quarter Tiling (Super + u/i/j/k) ─────────────────── -->

    <key name="snap-top-left" type="as">
      <default><![CDATA[['<Super>u']]]></default>
      <summary>Snap to Top-Left Quarter</summary>
    </key>

    <key name="snap-top-right" type="as">
      <default><![CDATA[['<Super>i']]]></default>
      <summary>Snap to Top-Right Quarter</summary>
    </key>

    <key name="snap-bottom-left" type="as">
      <default><![CDATA[['<Super>j']]]></default>
      <summary>Snap to Bottom-Left Quarter</summary>
    </key>

    <key name="snap-bottom-right" type="as">
      <default><![CDATA[['<Super>k']]]></default>
      <summary>Snap to Bottom-Right Quarter</summary>
    </key>

    <!-- ── Window Movement / Swap (Super+Shift + direction) ─────────── -->

    <key name="move-swap-left" type="as">
      <default><![CDATA[['<Super><Shift>Left']]]></default>
      <summary>Move/Swap Window Left</summary>
      <description>Move focused window one zone left; swap with occupant if any.</description>
    </key>

    <key name="move-swap-right" type="as">
      <default><![CDATA[['<Super><Shift>Right']]]></default>
      <summary>Move/Swap Window Right</summary>
      <description>Move focused window one zone right; swap with occupant if any.</description>
    </key>

    <key name="move-swap-up" type="as">
      <default><![CDATA[['<Super><Shift>Up']]]></default>
      <summary>Move/Swap Window Up</summary>
      <description>Move focused window one zone up; swap with occupant if any.</description>
    </key>

    <key name="move-swap-down" type="as">
      <default><![CDATA[['<Super><Shift>Down']]]></default>
      <summary>Move/Swap Window Down</summary>
      <description>Move focused window one zone down; swap with occupant if any.</description>
    </key>

    <!-- ── Focus & Auto-Tile ────────────────────────────────────────── -->

    <key name="focus-cycle-tiled" type="as">
      <default><![CDATA[['<Super>Tab']]]></default>
      <summary>Cycle Focus Between Tiled Windows</summary>
      <description>Move keyboard focus to the next snapped window in the current layout.</description>
    </key>

    <key name="auto-tile-grid" type="as">
      <default><![CDATA[['<Super>t']]]></default>
      <summary>Auto-Tile to Active Grid</summary>
      <description>Automatically tile all visible windows into the active zone layout.</description>
    </key>

    <!-- ── Monitor Movement (Super+Ctrl + direction) ────────────────── -->

    <key name="move-monitor-left" type="as">
      <default><![CDATA[['<Super><Primary>Left']]]></default>
      <summary>Move Window to Left Monitor</summary>
    </key>

    <key name="move-monitor-right" type="as">
      <default><![CDATA[['<Super><Primary>Right']]]></default>
      <summary>Move Window to Right Monitor</summary>
    </key>

    <!-- ── Layout & Overlay ─────────────────────────────────────────── -->

    <key name="open-snap-overlay" type="as">
      <default><![CDATA[['<Super>z']]]></default>
      <summary>Open Snap Layout Overlay</summary>
    </key>

    <key name="open-zone-editor" type="as">
      <default><![CDATA[['<Super>e']]]></default>
      <summary>Open Zone Editor</summary>
    </key>

    <key name="cycle-preset-next" type="as">
      <default><![CDATA[['<Super>bracketright']]]></default>
      <summary>Cycle to Next Preset</summary>
    </key>

    <key name="cycle-preset-prev" type="as">
      <default><![CDATA[['<Super>bracketleft']]]></default>
      <summary>Cycle to Previous Preset</summary>
    </key>

    <key name="restore-snap-group" type="as">
      <default><![CDATA[['<Super><Shift>g']]]></default>
      <summary>Restore Snap Group</summary>
    </key>

    <!-- ── Direct Zone Snap (advanced — unbound by default) ─────────── -->

    <key name="snap-to-zone-1" type="as">
      <default>[]</default>
      <summary>Snap to Zone 1</summary>
    </key>

    <key name="snap-to-zone-2" type="as">
      <default>[]</default>
      <summary>Snap to Zone 2</summary>
    </key>

    <key name="snap-to-zone-3" type="as">
      <default>[]</default>
      <summary>Snap to Zone 3</summary>
    </key>

    <key name="snap-to-zone-4" type="as">
      <default>[]</default>
      <summary>Snap to Zone 4</summary>
    </key>

    <key name="snap-to-zone-5" type="as">
      <default>[]</default>
      <summary>Snap to Zone 5</summary>
    </key>

    <key name="snap-to-zone-6" type="as">
      <default>[]</default>
      <summary>Snap to Zone 6</summary>
    </key>

  </schema>

</schemalist>
