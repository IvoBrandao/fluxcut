{
  "name": "window-tiling-control",
  "version": "1.0.0",
  "description": "WindowTilingControl — Window Snap Zones for GNOME Shell",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint extension.js prefs.js src/",
