    "@girs/gio-2.0": "^2.80.0-4.0.0",
    "@girs/gjs": "^4.0.0",
    "@girs/glib-2.0": "^2.80.0-4.0.0",
    "@girs/gobject-2.0": "^2.80.0-4.0.0",
    "@girs/gtk-4.0": "^4.14.0-4.0.0",
    "@girs/meta-14": "^14.0.0-4.0.0",
    "@girs/shell-14": "^14.0.0-4.0.0",
    "@girs/st-14": "^14.0.0-4.0.0",
    "eslint": "^9.0.0",
    "typescript": "~5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
